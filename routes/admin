  try {
    const vendor = await Vendor.findByIdAndUpdate(req.params.id, { approval_status: 'rejected' }, { new: true });
    await createNotification(vendor.user_id, `Your vendor application was rejected: ${req.body.reason || 'No reason provided'}`, 'rejection');
    res.json(vendor);
