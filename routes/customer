const router = require('express').Router();
const auth = require('../middleware/auth');
const role = require('../middleware/role');
const Vendor = require('../models/Vendor');
const Customer = require('../models/Customer');
const Order = require('../models/Order');
const Review = require('../models/Review');
const DeliveryPartner = require('../models/DeliveryPartner');
const { createNotification } = require('../utils/notify');

router.get('/vendors', async (req, res) => {
  try {
    const { search, cuisine, sort } = req.query;
    const filter = { approval_status: 'approved', is_active: true };
    if (cuisine && cuisine !== 'All') filter.cuisine_type = cuisine;
    if (search) filter['stall_name.en'] = { $regex: search, $options: 'i' };

    let query = Vendor.find(filter);
    if (sort === 'rating') query = query.sort({ average_rating: -1 });
    else if (sort === 'newest') query = query.sort({ created_at: -1 });

    const vendors = await query;
    res.json(vendors);
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

router.get('/vendors/:id', async (req, res) => {
  try {
    const vendor = await Vendor.findById(req.params.id);
    if (!vendor) return res.status(404).json({ message: 'Vendor not found' });

    const MenuItem = require('../models/MenuItem');
    const menu = await MenuItem.find({ vendor_id: vendor._id });
    res.json({ vendor, menu });
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

router.use(auth, role('customer'));

router.post('/orders', async (req, res) => {
  try {
    const customer = await Customer.findOne({ user_id: req.user.id });
    const { vendor_id, items, total_amount, delivery_address } = req.body;

    const deliveryPartner = await DeliveryPartner.findOne({
      is_available: true,
      approval_status: 'approved'
    });

    const order = await Order.create({
      customer_id: customer._id,
      vendor_id,
      delivery_partner_id: deliveryPartner?._id || null,
      items,
      total_amount,
      delivery_address
    });

    const vendor = await Vendor.findById(vendor_id);
    await createNotification(vendor.user_id, 'New order received!', 'new_order');

    if (deliveryPartner) {
      await createNotification(deliveryPartner.user_id, 'New delivery job assigned!', 'delivery_job');
    }

    res.status(201).json(order);
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

router.get('/orders', async (req, res) => {
  try {
    const customer = await Customer.findOne({ user_id: req.user.id });
    const orders = await Order.find({ customer_id: customer._id })
      .sort({ created_at: -1 })
      .populate('vendor_id')
      .populate('delivery_partner_id');
    res.json(orders);
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

router.get('/orders/:id', async (req, res) => {
  try {
    const order = await Order.findById(req.params.id)
      .populate('vendor_id')
      .populate('delivery_partner_id');
    res.json(order);
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

router.post('/orders/:id/review', async (req, res) => {
  try {
    const customer = await Customer.findOne({ user_id: req.user.id });
    const order = await Order.findById(req.params.id);

    const review = await Review.create({
      order_id: order._id,
      customer_id: customer._id,
      vendor_id: order.vendor_id,
      delivery_partner_id: order.delivery_partner_id,
      ...req.body
    });

    // Update vendor rating
    const vendorReviews = await Review.find({ vendor_id: order.vendor_id });
    const avgRating = vendorReviews.reduce((s, r) => s + (r.vendor_ratings?.overall || 0), 0) / vendorReviews.length;
    await Vendor.findByIdAndUpdate(order.vendor_id, {
      average_rating: Math.round(avgRating * 10) / 10,
      total_reviews: vendorReviews.length
    });

    const vendor = await Vendor.findById(order.vendor_id);
    await createNotification(vendor.user_id, 'You received a new review!', 'review');

    if (order.delivery_partner_id) {
      const dp = await DeliveryPartner.findById(order.delivery_partner_id);
      const dpReviews = await Review.find({ delivery_partner_id: dp._id });
      const dpAvg = dpReviews.reduce((s, r) => s + (r.delivery_ratings?.overall || 0), 0) / dpReviews.length;
      dp.average_rating = Math.round(dpAvg * 10) / 10;
      dp.total_reviews = dpReviews.length;
      await dp.save();
      await createNotification(dp.user_id, 'You received a new delivery review!', 'review');
    }

    res.status(201).json(review);
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

router.patch('/profile', async (req, res) => {
  try {
    const { name, phone, saved_addresses } = req.body;
    if (name || phone) {
      await require('../models/User').findByIdAndUpdate(req.user.id, { name, phone });
    }
    if (saved_addresses) {
      await Customer.findOneAndUpdate({ user_id: req.user.id }, { saved_addresses });
    }
    res.json({ message: 'Profile updated' });
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

router.post('/favourites/:vendorId', async (req, res) => {
  try {
    const customer = await Customer.findOne({ user_id: req.user.id });
    const idx = customer.favourite_vendors.indexOf(req.params.vendorId);
    if (idx > -1) customer.favourite_vendors.splice(idx, 1);
    else customer.favourite_vendors.push(req.params.vendorId);
    await customer.save();
    res.json(customer.favourite_vendors);
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

router.get('/favourites', async (req, res) => {
  try {
    const customer = await Customer.findOne({ user_id: req.user.id }).populate('favourite_vendors');
    res.json(customer.favourite_vendors);
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

module.exports = router;
