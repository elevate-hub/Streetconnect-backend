const router = require('express').Router();
const MenuItem = require('../models/MenuItem');
const Vendor = require('../models/Vendor');
const auth = require('../middleware/auth');
const User = require('../models/User');
const { translateToEnglish } = require('../utils/translate');

// Get all menu items for a vendor
router.get('/vendor/:vendorId', async (req, res) => {
  try {
    const items = await MenuItem.find({ vendor_id: req.params.vendorId });
    res.json(items);
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

// Get all menu items for current logged-in vendor
router.get('/', auth, async (req, res) => {
  try {
    const user = await User.findById(req.user.id);
    if (user.role !== 'vendor') return res.status(403).json({ message: 'Not a vendor' });

    const vendor = await Vendor.findOne({ user_id: req.user.id });
    if (!vendor) return res.status(404).json({ message: 'Vendor profile not found' });

    const items = await MenuItem.find({ vendor_id: vendor._id });
    res.json(items);
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

// Create new menu item
router.post('/', auth, async (req, res) => {
  try {
    const user = await User.findById(req.user.id);
    if (user.role !== 'vendor') return res.status(403).json({ message: 'Not a vendor' });

    const vendor = await Vendor.findOne({ user_id: req.user.id });
    if (!vendor) return res.status(404).json({ message: 'Vendor profile not found' });

    const {
      name_kn,
      name_en,
      description_kn,
      description_en,
      name,
      description,
      price,
      image_url,
      is_available,
      category
    } = req.body;

    const rawNameKn = name_kn || (typeof name === 'object' ? name.kn : name) || '';
    const rawNameEn = name_en || (typeof name === 'object' ? name.en : undefined) || '';
    const rawDescriptionKn = description_kn || (typeof description === 'object' ? description.kn : description) || '';
    const rawDescriptionEn = description_en || (typeof description === 'object' ? description.en : undefined) || '';

    if (!rawNameKn || !price) {
      return res.status(400).json({ message: 'Kannada name and price are required' });
    }

    const translatedNameEn = rawNameEn || await translateToEnglish(rawNameKn);
    const translatedDescriptionEn = rawDescriptionEn || (rawDescriptionKn ? await translateToEnglish(rawDescriptionKn) : '');

    const item = await MenuItem.create({
      vendor_id: vendor._id,
      name: {
        kn: rawNameKn,
        en: translatedNameEn || rawNameKn
      },
      price,
      category: category || 'General',
      description: {
        kn: rawDescriptionKn,
        en: translatedDescriptionEn || rawDescriptionKn
      },
      image_url: image_url || null,
      is_available: is_available !== undefined ? is_available : true
    });

    res.status(201).json(item);
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

// Update menu item
router.patch('/:id', auth, async (req, res) => {
  try {
    const user = await User.findById(req.user.id);
    if (user.role !== 'vendor') return res.status(403).json({ message: 'Not a vendor' });

    const item = await MenuItem.findById(req.params.id);
    if (!item) return res.status(404).json({ message: 'Item not found' });

    const vendor = await Vendor.findOne({ user_id: req.user.id });
    if (item.vendor_id.toString() !== vendor._id.toString()) {
      return res.status(403).json({ message: 'Not authorized' });
    }

    const {
      name_kn,
      name_en,
      description_kn,
      description_en,
      name,
      description,
      price,
      image_url,
      is_available,
      category
    } = req.body;

    if (name_kn || name_en || name) {
      const rawNameKn = name_kn || (typeof name === 'object' ? name.kn : name) || item.name?.kn || '';
      let rawNameEn = name_en || (typeof name === 'object' ? name.en : (typeof name === 'string' ? name : undefined));

      if (rawNameKn && !rawNameEn) {
        rawNameEn = await translateToEnglish(rawNameKn);
      }

      item.name = {
        kn: rawNameKn || item.name?.kn || rawNameEn || '',
        en: rawNameEn || item.name?.en || rawNameKn || ''
      };
    }

    if (description_kn || description_en || description !== undefined) {
      const rawDescriptionKn = description_kn || (typeof description === 'object' ? description.kn : description) || item.description?.kn || '';
      let rawDescriptionEn = description_en || (typeof description === 'object' ? description.en : (typeof description === 'string' ? description : undefined));

      if (rawDescriptionKn && !rawDescriptionEn) {
        rawDescriptionEn = await translateToEnglish(rawDescriptionKn);
      }

      item.description = {
        kn: rawDescriptionKn || item.description?.kn || rawDescriptionEn || '',
        en: rawDescriptionEn || item.description?.en || rawDescriptionKn || ''
      };
    }

    if (price !== undefined) item.price = price;
    if (category !== undefined) item.category = category;
    if (image_url !== undefined) item.image_url = image_url;
    if (is_available !== undefined) item.is_available = is_available;

    await item.save();
    res.json(item);
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

// Delete menu item
router.delete('/:id', auth, async (req, res) => {
  try {
    const user = await User.findById(req.user.id);
    if (user.role !== 'vendor') return res.status(403).json({ message: 'Not a vendor' });

    const item = await MenuItem.findById(req.params.id);
    if (!item) return res.status(404).json({ message: 'Item not found' });

    const vendor = await Vendor.findOne({ user_id: req.user.id });
    if (item.vendor_id.toString() !== vendor._id.toString()) {
      return res.status(403).json({ message: 'Not authorized' });
    }

    await MenuItem.deleteOne({ _id: req.params.id });
    res.json({ message: 'Item deleted' });
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

// Toggle availability
router.patch('/:id/toggle', auth, async (req, res) => {
  try {
    const user = await User.findById(req.user.id);
    if (user.role !== 'vendor') return res.status(403).json({ message: 'Not a vendor' });

    const item = await MenuItem.findById(req.params.id);
    if (!item) return res.status(404).json({ message: 'Item not found' });

    const vendor = await Vendor.findOne({ user_id: req.user.id });
    if (item.vendor_id.toString() !== vendor._id.toString()) {
      return res.status(403).json({ message: 'Not authorized' });
    }

    item.is_available = !item.is_available;
    await item.save();
    res.json(item);
  } catch (err) {
    res.status(500).json({ message: err.message });
  }
});

module.exports = router;
